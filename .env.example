# Production retrieval and ingestion
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin API. Use a long random value and never expose it through NEXT_PUBLIC_*.
ADMIN_INGEST_TOKEN=

# Public canonical URL after deployment, for ChatGPT/MCP connection instructions.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional local-only override when YouTube's embed page does not expose its client key.
YOUTUBE_INNERTUBE_API_KEY=
